<style>
  :root{--ink:#1a1410;--cream:#f5f0e8;--warm:#ede5d8;--gold:#b8924a;--muted:#7a6e62;--deep:#221c15;}
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--cream);color:var(--ink);font-family:'Jost',sans-serif;font-weight:300;overflow-x:hidden;}
  .blog-nav{padding:24px 64px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(184,146,74,.15);}
  .blog-nav a{text-decoration:none;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);transition:color .3s;}
  .blog-nav a:hover{color:var(--gold);}
  .nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;color:var(--ink);}

  /* HERO DESTAQUE */
  .article-hero{background:var(--deep);padding:80px 64px;text-align:center;}
  .article-hero .tag{font-size:.68rem;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:28px;}
  .article-hero .tag::before,.article-hero .tag::after{content:'';display:block;width:28px;height:1px;background:var(--gold);}
  .article-hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,4vw,3.6rem);font-weight:300;line-height:1.1;color:var(--cream);}
  .article-hero h1 em{font-style:italic;color:var(--gold);}
