  .article-wrap{max-width:720px;margin:0 auto;padding:80px 32px 120px;}
  .article-body h2{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:400;line-height:1.2;margin:48px 0 16px;}
  .article-body p{font-size:.95rem;line-height:1.95;color:var(--muted);margin-bottom:20px;}
  .article-body hr{border:none;border-top:1px solid rgba(184,146,74,.2);margin:40px 0;}

  /* BOTÃO WA INLINE */
  .cta-inline{margin:40px 0;padding:36px 40px;background:var(--deep);display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
  .cta-inline p{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;font-style:italic;color:var(--cream);line-height:1.4;flex:1;}
  .btn-wa{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;background:#25D366;color:#fff;font-size:.75rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;transition:background .3s;white-space:nowrap;}
  .btn-wa:hover{background:#1ebe5d;}
  .btn-wa svg{flex-shrink:0;}

  .author-box{margin-top:48px;padding:32px;border:1px solid rgba(184,146,74,.2);}
  .author-box h3{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;margin-bottom:6px;}
  .author-box p{font-size:.82rem;line-height:1.75;color:var(--muted);}
  .back-link{display:inline-flex;align-items:center;gap:8px;margin-top:48px;font-size:.75rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .3s;}
  .back-link:hover{color:var(--gold);}
  .wa-float{position:fixed;bottom:32px;right:32px;z-index:999;width:58px;height:58px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.45);text-decoration:none;}
  .wa-float svg{width:28px;height:28px;fill:#fff;}
  .wa-float::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:2px solid rgba(37,211,102,.4);animation:waPulse 2.5s ease-out infinite;}
  @keyframes waPulse{0%{transform:scale(1);opacity:.8;}100%{transform:scale(1.6);opacity:0;}}
  footer{background:var(--deep);padding:26px 64px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
  footer p{font-size:.69rem;letter-spacing:.1em;color:rgba(245,240,232,.22);}
  footer a{color:rgba(184,146,74,.55);font-size:.69rem;text-decoration:none;}
  @media(max-width:768px){.blog-nav{padding:20px 24px;}.article-hero{padding:60px 24px;}.article-wrap{padding:48px 24px 80px;}.cta-inline{flex-direction:column;padding:28px 24px;}.cta-inline p{text-align:center;}.btn-wa{width:100%;justify-content:center;}footer{padding:20px 24px;flex-direction:column;}}
